{
  "name": "bexoe-word-counter",
  "displayName": "Bexoe Word Counter",
  "description": "Shows word count in the status bar",
  "version": "0.1.0",
  "publisher": "bexoe",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "bexoe.wordCounter.showCount",
        "title": "Bexoe: Show Word Count"
      }
    ]
  }
}
