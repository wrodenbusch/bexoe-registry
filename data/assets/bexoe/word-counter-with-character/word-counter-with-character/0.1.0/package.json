{
  "name": "bexoe-word-counter",
  "displayName": "Word & Character Counter",
  "description": "Displays word count and character count in the status bar",
  "version": "0.1.0",
  "publisher": "bexoe",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "bexoe.wordCounter.showCount",
        "title": "Show Word & Character Count"
      }
    ]
  }
}
